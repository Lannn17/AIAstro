# ── Auth 认证 ────────────────────────────────────────────────
# 登录用户名和密码（分享公网链接时使用）
AUTH_USERNAME=admin
AUTH_PASSWORD=your_password_here
# JWT 签名密钥（必须是强随机字符串，生产环境务必修改）
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Turso 数据库（本地开发和线上部署均填入，填入后本地也使用 Turso，留空才退回本地 charts.db）
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Google Gemini（RAG 生成）
GOOGLE_API_KEY=your_google_api_key_here

# Qdrant Cloud（向量检索）
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Environment (development or production)
# ENVIRONMENT=development

# SiliconFlow (CN region AI fallback)
SILICONFLOW_API_KEY=your_siliconflow_key_here

# 高德地图（CN region 地理编码）
# AMAP_SECURITY_KEY: JS API 安全密钥，通过 /_AMapService 代理注入，绝不暴露前端
# JS API key（VITE_AMAP_KEY）填写在 frontend/.env 中
AMAP_SECURITY_KEY=your_amap_security_js_code_here

# Debug observability（留空则 /api/debug/* 全部返回 503）
DEBUG_TOKEN=
